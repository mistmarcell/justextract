generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum JobType {
  AUDIO_EXTRACT
  VIDEO_SPLIT
  CLIP_EXPORT
  AUDIO_EXPORT
  URL_IMPORT
  WAVEFORM_GENERATE
}

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String?   @unique
  passwordHash  String?
  name          String?
  avatarUrl     String?
  role          UserRole  @default(USER)
  provider      String?
  providerId    String?
  storageUsed   Int       @default(0)
  storageLimit  Int       @default(10737418240)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects  Project[]
  jobs      Job[]
  sessions  Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Project {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  title     String   @default("Untitled Project")
  thumbnail String?
  duration  Float?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  media   Media[]
  clips   Clip[]
  markers TimelineMarker[]

  @@map("projects")
}

model Media {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId     String?  @db.ObjectId
  userId        String?  @db.ObjectId
  originalName  String
  filename      String
  mimeType      String
  size          Int
  duration      Float?
  width         Int?
  height        Int?
  fps           Float?
  codec         String?
  bitrate       Int?
  audioCodec    String?
  audioChannels Int?
  sampleRate    Int?
  fileHash      String?
  thumbnail     String?
  source        String   @default("upload")
  url           String?
  metadata      String?
  createdAt     DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs    Job[]

  @@map("media")
}

model TimelineMarker {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  time      Float
  type      String   @default("split")
  label     String?
  color     String?
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("timeline_markers")
}

model Clip {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  name      String?
  startTime Float
  endTime   Float
  color     String?
  locked    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("clips")
}

model Job {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?   @db.ObjectId
  mediaId       String?   @db.ObjectId
  type          JobType
  status        JobStatus @default(PENDING)
  progress      Float     @default(0)
  params        String?
  output        String?
  outputPath    String?
  outputSize    Int?
  error         String?
  thumbnail     String?
  priority      Int       @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  media Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@map("jobs")
}

model AdminLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  userId    String?  @db.ObjectId
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@map("admin_logs")
}

model SystemSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
